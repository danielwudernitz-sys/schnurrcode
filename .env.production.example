# =============================================================
# Schnurrcode — PRODUKTIONS-Variablen (in Vercel eintragen)
# Reihenfolge = Priorität. Werte aus den jeweiligen Dashboards.
# NICHT committen. ALLOW_DEV_LOGIN hier NIEMALS setzen.
# =============================================================

# --- Basis (Pflicht) ---
NEXT_PUBLIC_SITE_URL=https://schnurrcode.com
AUTH_SECRET=                      # langer Zufallswert (siehe GO-LIVE.md)

# --- Datenbank: Supabase (EU/Frankfurt) (Pflicht für Login) ---
SUPABASE_URL=                     # Project Settings → API → Project URL
SUPABASE_SERVICE_KEY=             # Project Settings → API → service_role (secret!)

# --- E-Mail: Brevo (EU) (Pflicht für Login-/Lead-Mails) ---
BREVO_API_KEY=                    # Brevo → SMTP & API → API Keys
BREVO_FROM_EMAIL=hallo@schnurrcode.com   # verifizierte Absenderadresse

# --- Zahlung: Stripe (von dir bereits eingerichtet) ---
STRIPE_SECRET_KEY=                # Stripe → Developers → API keys (sk_live_…)
STRIPE_WEBHOOK_SECRET=            # Stripe → Webhooks → dein Endpoint (whsec_…)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_live_…  (optional, aktuell nicht zwingend)

# --- Preis (A/B): 2900 = 29 €, 1900 = 19 € ---
NEXT_PUBLIC_PRICE_CENTS=2900

# --- Optional: KI-Übersetzer (Freitext) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Optional: Analytics / Meta Pixel (erst nach Consent) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=schnurrcode.com
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=

# WICHTIG: ALLOW_DEV_LOGIN hier NICHT setzen (nur lokal).

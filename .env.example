# Schnurrcode — Secrets (EU-Region). Kopiere zu .env.local und befülle.
# NIE committen. Alle Daten/Dienste in der EU halten (DSGVO).
# Ohne diese Werte läuft die App im Dev-Modus mit Fallbacks (E-Mails werden
# geloggt statt versendet, DB-Schreibvorgänge sind No-Ops, Zahlung deaktiviert).

# Basis
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Session-Signatur — in PRODUKTION zwingend setzen (langer Zufallswert)!
AUTH_SECRET=

# DEV-LOGIN-BYPASS — NUR LOKAL. Wenn "true", darf sich JEDE E-Mail einloggen,
# OHNE Kauf. Greift ausschließlich, wenn KEINE Datenbank konfiguriert ist
# (lokal ohne Keys). In Produktion ist Supabase gesetzt → der Bypass ist
# automatisch inaktiv. NIEMALS in Produktion auf "true" setzen.
ALLOW_DEV_LOGIN=false

# Preis (A/B): 2900 = 29 €, 1900 = 19 €
NEXT_PUBLIC_PRICE_CENTS=2900

# Stripe (Prompt 8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Brevo / E-Mail (EU) (Prompt 3 + 8)
BREVO_API_KEY=
BREVO_FROM_EMAIL=hallo@schnurrcode.com
BREVO_LIST_LEADS=

# Datenbank (Supabase EU / Frankfurt) (Prompt 8)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-Key nur serverseitig nutzen (Schreibzugriff)
SUPABASE_SERVICE_KEY=

# Anthropic (optionaler KI-Decoder, Prompt 5b)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Analytics / Meta Pixel (Prompt 12) — erst nach Consent feuern
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=
